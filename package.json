{
  "name": "ai-docs-generator",
  "version": "1.0.0",
  "description": "AI-powered technical documentation generator that watches GitHub repos and auto-generates docs on PR merge",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "worker": "node src/worker.js",
    "dev": "node --watch src/index.js",
    "dev:worker": "node --watch src/worker.js",
    "generate": "node scripts/generateDocs.js",
    "docs:dev": "npx docsify-cli serve docs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@octokit/rest": "^20.1.1",
    "bullmq": "^5.7.8",
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "ioredis-mock": "^8.13.1"
  }
}
